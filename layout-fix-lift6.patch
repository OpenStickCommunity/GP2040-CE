+
+    // When the viewport is shrunk for the input-history row (viewport.top > 0),
+    // lift the layout up a few pixels so it sits balanced in its band rather
+    // than crowding the history. Tunable; 0 disables. History off -> top==0 ->
+    // no effect.
+    const uint16_t INPUT_HISTORY_LAYOUT_LIFT = 6;
+    if (this->getViewport().top > 0) {
+        // Clamp so an over-large lift can never wrap the unsigned offset.
+        offsetY -= (offsetY < INPUT_HISTORY_LAYOUT_LIFT) ? offsetY : INPUT_HISTORY_LAYOUT_LIFT;
+    }
 
     if (scaleX > 0.0f) {
