     	getRenderer()->drawText(0, 0, statusBar, true);
     } else {
-		getRenderer()->drawText(0, 0, statusBar);
+		getRenderer()->drawText(0, 0, getScrolledStatusBar());
 	}
     getRenderer()->drawText(0, 7, footer);
 }
