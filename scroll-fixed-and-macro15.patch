+std::string ButtonLayoutScreen::getScrolledStatusBar() {
+    // Display fits 20 chars at the 6x8 font before the OBD driver's word-wrap
+    // kicks in (wrap triggers at width-7 = 121px; 21 chars = 126px would wrap
+    // onto the next row and push the button layout down). If the bar fits,
+    // return it unchanged and reset any scroll state.
+    const size_t displayChars = 20;
+
+    if (statusBar.length() <= displayChars) {
+        statusBarScrollInit = false;
+        statusBarScrollOffset = 0;
+        statusBarScrollContent.clear();
+        return statusBar;
+    }
+
+    // Re-anchor whenever the content changes (e.g. the user toggles SOCD,
+    // turbo, or profile), so the scroll restarts cleanly from the left
+    // instead of jumping mid-stream against a different string length.
+    if (!statusBarScrollInit || statusBar != statusBarScrollContent) {
+        statusBarScrollInit = true;
+        statusBarScrollContent = statusBar;
+        statusBarScrollStart = getMillis();
+        statusBarScrollOffset = 0;
+    }
+
+    // Build a looping marquee: full string + gap, so it wraps cleanly.
+    const std::string gap = "   ";
+    std::string marquee = statusBar + gap;
+
+    // Advance one character every scrollIntervalMs, after an initial hold.
+    const uint32_t scrollIntervalMs = 350;
+    const uint32_t initialHoldMs = 1500;
+
+    uint32_t elapsed = getMillis() - statusBarScrollStart;
+    if (elapsed > initialHoldMs) {
+        statusBarScrollOffset = ((elapsed - initialHoldMs) / scrollIntervalMs) % marquee.length();
+    } else {
+        statusBarScrollOffset = 0;
+    }
+
+    // Extract a display-width window starting at the offset, wrapping around.
+    std::string window;
+    window.reserve(displayChars);
+    for (size_t i = 0; i < displayChars; i++) {
+        window += marquee[(statusBarScrollOffset + i) % marquee.length()];
+    }
+    return window;
+}
+
